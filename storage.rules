rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Profile photos (signup uploads). Client uses getDownloadURL() token URLs;
    // those requests succeed without evaluating these rules. Direct reads without
    // a token still require a signed-in Firebase user.
    match /profile_photos/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Tourist QR card PNGs (one folder per user; path must match auth uid).
    match /tourist_qr_cards/{userId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
